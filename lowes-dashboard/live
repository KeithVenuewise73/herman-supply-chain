const buildDriverRows = (speRows, ltrRows, useNeutral) => {
  const map = {};
  speRows.forEach((r) => {
    const key = normalizeName(r.speName + r.carrier);
    if (!map[key]) map[key] = { ...r, ltrResponses: [] };
    ["routes", "plannedStops", "actualStops", "redeliveries"].forEach((f) => { map[key][f] = (map[key][f] || 0) + (r[f] || 0); });
    ["completion", "onTimeInWindow", "onTime", "redeliveryPct"].forEach((f) => {
      map[key]["_sum_" + f] = (map[key]["_sum_" + f] || 0) + (r[f] || 0);
      map[key]["_cnt_" + f] = (map[key]["_cnt_" + f] || 0) + 1;
    });
  });
  ltrRows.forEach((r) => {
    const normCC = normalizeName(r.contractorCarrier);
    const key = Object.keys(map).find((k) => {
      const speN = normalizeName(map[k].speName);
      return normCC && speN && (speN.includes(normCC) || normCC.includes(speN));
    });
    if (key) map[key].ltrResponses.push(r.ltr);
  });
  return Object.values(map).map((r) => {
    const avg = (f) => r["_cnt_" + f] ? r["_sum_" + f] / r["_cnt_" + f] : null;
    const ltr = calcLTR(r.ltrResponses);
    const row = {
      name: r.speName, carrier: r.carrier, region: r.region, district: r.district, weekEnding: r.weekEnding,
      routes: r.routes, plannedStops: r.plannedStops, actualStops: r.actualStops, completion: avg("completion"),
      onTimeInWindow: avg("onTimeInWindow"), onTime: avg("onTime"), redeliveryPct: avg("redeliveryPct"),
      ltrTotal: ltr.total, ltrCount910: ltr.count910, ltrCount8: ltr.count8, ltrCount07: ltr.count07,
      ltrStrict: ltr.strict, ltrNeutral: ltr.neutral, lowSample: ltr.total < 5,
    };
    row.composite = compositeScore(row, useNeutral);
    return row;
  }).sort((a, b) => (b.composite || 0) - (a.composite || 0)).map((r, i) => ({ ...r, rank: i + 1 }));
};
const buildCarrierRows = (spRows, ltrRows, useNeutral) => {
  const map = {};
  spRows.forEach((r) => {
    const key = normalizeName(r.carrier);
    if (!map[key]) map[key] = { ...r, ltrResponses: [] };
    ["routes", "plannedStops", "actualStops", "redeliveries"].forEach((f) => { map[key][f] = (map[key][f] || 0) + (r[f] || 0); });
    ["completion", "onTimeInWindow", "onTime", "redeliveryPct"].forEach((f) => {
      map[key]["_sum_" + f] = (map[key]["_sum_" + f] || 0) + (r[f] || 0);
      map[key]["_cnt_" + f] = (map[key]["_cnt_" + f] || 0) + 1;
    });
  });
  ltrRows.forEach((r) => {
    const normC = normalizeName(r.carrier);
    const key = Object.keys(map).find((k) => k === normC || k.includes(normC) || normC.includes(k));
    if (key) map[key].ltrResponses.push(r.ltr);
  });
  return Object.values(map).map((r) => {
    const avg = (f) => r["_cnt_" + f] ? r["_sum_" + f] / r["_cnt_" + f] : null;
    const ltr = calcLTR(r.ltrResponses);
    const row = {
      carrier: r.carrier, region: r.region, district: r.district, weekEnding: r.weekEnding,
      routes: r.routes, plannedStops: r.plannedStops, actualStops: r.actualStops, completion: avg("completion"),
      onTimeInWindow: avg("onTimeInWindow"), onTime: avg("onTime"), redeliveryPct: avg("redeliveryPct"),
      ltrTotal: ltr.total, ltrCount910: ltr.count910, ltrCount8: ltr.count8, ltrCount07: ltr.count07,
      ltrStrict: ltr.strict, ltrNeutral: ltr.neutral, lowSample: ltr.total < 5,
    };
    row.composite = compositeScore(row, useNeutral);
    return row;
  }).sort((a, b) => (b.composite || 0) - (a.composite || 0)).map((r, i) => ({ ...r, rank: i + 1 }));
};
const buildStoreRows = (ltrRows) => {
  const map = {};
  ltrRows.forEach((r) => {
    const key = r.store.number || r.store.name;
    if (!map[key]) map[key] = { store: r.store, ltrResponses: [], detractors: [], comments: [] };
    map[key].ltrResponses.push(r.ltr);
    if (r.detractor) map[key].detractors.push(r.detractor);
    if (r.improvementComment) map[key].comments.push(r.improvementComment);
  });
  return Object.values(map).map((r) => {
    const ltr = calcLTR(r.ltrResponses);
    const detCounts = {};
    r.detractors.forEach((d) => { detCounts[d] = (detCounts[d] || 0) + 1; });
    const topDet = Object.entries(detCounts).sort((a, b) => b[1] - a[1])[0]?.[0] || "—";
    return {
      storeNum: r.store.number, storeName: r.store.name, ltrTotal: ltr.total, ltrCount910: ltr.count910,
      ltrCount8: ltr.count8, ltrCount07: ltr.count07, ltrStrict: ltr.strict, ltrNeutral: ltr.neutral,
      detractorCount: r.detractors.length, topDetractor: topDet, lowSample: ltr.total < 5, comments: r.comments,
    };
  }).sort((a, b) => (b.ltrStrict || 0) - (a.ltrStrict || 0)).map((r, i) => ({ ...r, rank: i + 1 }));
};

