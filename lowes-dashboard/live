  if (sortCol !== col) return <span style={{ color: "#475569", marginLeft: 4 }}>↕</span>;
  return <span style={{ color: "#38bdf8", marginLeft: 4 }}>{sortDir === "asc" ? "↑" : "↓"}</span>;
