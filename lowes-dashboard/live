const UploadPage = ({ onLoad }) => {
  const [kpiFile, setKpiFile] = useState(null);
  const [ltrFile, setLtrFile] = useState(null);
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);
  const [progress, setProgress] = useState("");
  const [loadingDB, setLoadingDB] = useState(false);

  const readFile = (file) => new Promise((res, rej) => {
    const r = new FileReader();
    r.onload = (e) => res(new Uint8Array(e.target.result));
    r.onerror = rej;
    r.readAsArrayBuffer(file);
  });

  const handleLoad = async () => {
    if (!kpiFile || !ltrFile) { setError("Please upload both files."); return; }
    setLoading(true); setError(""); setProgress("Parsing Excel files...");
    try {
      const [kpi, ltr] = await Promise.all([readFile(kpiFile), readFile(ltrFile)]);
      const data = parseFiles(kpi, ltr);
      setProgress("Syncing to Supabase...");
      await syncToSupabase(data.spRows, data.speRows, data.ltrRows, setProgress);
      onLoad(data);
    } catch (e) { setError("Error: " + e.message); }
    setLoading(false); setProgress("");
  };

  const handleLoadFromDB = async () => {
    setLoadingDB(true); setError("");
    try {
      const data = await loadFromSupabase();
      if (!data.ltrRows.length && !data.spRows.length) setError("No data found in database. Please upload Excel files first.");
      else onLoad(data);
    } catch (e) { setError("Error loading from database: " + e.message); }
    setLoadingDB(false);
  };

  const DropZone = ({ label, file, onFile }) => {
    const ref = useRef();
    return (
      <div onClick={() => ref.current.click()} onDragOver={(e) => e.preventDefault()} onDrop={(e) => { e.preventDefault(); onFile(e.dataTransfer.files[0]); }}
        style={{ border: "2px dashed #334155", borderRadius: 12, padding: "40px 24px", textAlign: "center", cursor: "pointer", background: file ? "rgba(56,189,248,0.05)" : "#0f172a", borderColor: file ? "#38bdf8" : "#334155" }}>
        <input ref={ref} type="file" accept=".xlsx,.xls" style={{ display: "none" }} onChange={(e) => onFile(e.target.files[0])} />
        <div style={{ fontSize: 32, marginBottom: 8 }}>📊</div>
        <div style={{ color: file ? "#38bdf8" : "#64748b", fontWeight: 600 }}>{file ? file.name : label}</div>
        <div style={{ color: "#475569", fontSize: 12, marginTop: 4 }}>Click or drag & drop .xlsx</div>
      </div>
    );
  };

  return (
    <div style={{ maxWidth: 700, margin: "40px auto", padding: "0 20px" }}>
      <h2 style={{ color: "#f1f5f9", fontSize: 22, marginBottom: 8 }}>Upload / Refresh Data</h2>
      <p style={{ color: "#64748b", marginBottom: 24 }}>Upload your Excel files to sync fresh data to Supabase, or load the last saved dataset.</p>
      <div style={{ background: "#0f172a", border: "1px solid #1e3a5f", borderRadius: 12, padding: 20, marginBottom: 28, display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div>
          <div style={{ color: "#38bdf8", fontWeight: 600, marginBottom: 4 }}>📦 Load from Supabase</div>
          <div style={{ color: "#64748b", fontSize: 13 }}>Load the last uploaded dataset without re-uploading files</div>
        </div>
        <button onClick={handleLoadFromDB} disabled={loadingDB} style={{ background: "linear-gradient(90deg,#0369a1,#1d4ed8)", color: "#fff", border: "none", borderRadius: 8, padding: "10px 24px", fontSize: 14, fontWeight: 600, cursor: "pointer" }}>
          {loadingDB ? "Loading..." : "Load Data"}
        </button>
      </div>
      <div style={{ color: "#475569", textAlign: "center", marginBottom: 20, fontSize: 13 }}>— or upload new Excel files —</div>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20, marginBottom: 24 }}>
        <DropZone label="Lowe's Carrier KPI (.xlsx)" file={kpiFile} onFile={setKpiFile} />
        <DropZone label="LTR Detractor Sheet (.xlsx)" file={ltrFile} onFile={setLtrFile} />
      </div>
      {progress && <div style={{ background: "#1e293b", borderRadius: 8, padding: "10px 16px", marginBottom: 16, color: "#38bdf8", fontSize: 13 }}>⏳ {progress}</div>}
      {error && <div style={{ color: "#f87171", marginBottom: 16, fontSize: 13 }}>⚠ {error}</div>}
      <button onClick={handleLoad} disabled={loading} style={{ background: "linear-gradient(90deg,#0ea5e9,#3b82f6)", color: "#fff", border: "none", borderRadius: 8, padding: "12px 32px", fontSize: 15, fontWeight: 600, cursor: "pointer", width: "100%" }}>
        {loading ? progress || "Processing…" : "Upload & Sync to Supabase"}
      </button>
    </div>
  );
};

